    "register_admin":       "mutation { registerUser(input: {username: \"%s\", password: \"%s\", role: \"admin\"}) { user { username role } } }",
    "register_basic":       "mutation { registerUser(input: {username: \"%s\", password: \"%s\"}) { user { username } } }",
    "register_superadmin":  "mutation { registerUser(input: {username: \"%s\", password: \"%s\", role: \"superadmin\"}) { user { username role } } }",
    "register_moderator":   "mutation { registerUser(input: {username: \"%s\", password: \"%s\", role: \"moderator\"}) { user { username role } } }",
    "update_role":          "mutation { updateUser(username: \"%s\", role: \"admin\") { username role } }",
    "update_password":      "mutation { updateUser(username: \"%s\", password: \"%s\") { username } }",
    "delete_user":          "mutation { deleteUser(username: \"%s\") { success } }",
    "login":                "mutation { login(username: \"%s\", password: \"%s\") { token user { username role } } }",
    "input_type_enum":      "{ __type(name: \"%s\") { name inputFields { name description defaultValue type { name kind } } } }"
